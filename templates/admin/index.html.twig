{% extends 'base.html.twig' %}

{% block title %}Hello AdminController!{% endblock %}

{% block body %}
<style>
    .example-wrapper { margin: 1em auto; max-width: 800px; width: 95%; font: 18px/1.5 sans-serif; }
    .example-wrapper code { background: #F5F5F5; padding: 2px 6px; }
</style>

<div class="example-wrapper">
    <h1>admin/index.twig</h1>
    <h1>Hello {{ controller_name }}! ✅</h1>
</div>

<h1>Admin - Produits</h1>
<a href="{{ path('app_admin_dashboard') }}">Dashboard</a>
<br>
<a href="{{ path('admin_product_new') }}">Ajouter un produit</a>

<table>
    <thead>
        <tr>
            <th>Nom</th>
            <th>Prix</th>
            <th>Mis en avant</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        {% for product in products %}
            <tr>
                <td>{{ product.name }}</td>
                <td>{{ product.price }} €</td>
                <td>{{ product.featured ? 'Oui' : 'Non' }}</td>
                <td>
                    <a href="{{ path('admin_product_edit', {'id': product.id}) }}">Modifier</a>
                    <form action="{{ path('admin_product_delete', {'id': product.id}) }}" method="POST" style="display:inline">
                        <button type="submit" onclick="return confirm('Supprimer ce produit ?')">Supprimer</button>
                    </form>
                </td>
            </tr>
            <tr>
                <td>
                    {% for stock in product.stocks %}
                        {{ stock.size }} : {{ stock.quantity }} <br>
                    {% endfor %}
                </td>
            </tr>
        {% endfor %}

        
    </tbody>
</table>
{% endblock %}
