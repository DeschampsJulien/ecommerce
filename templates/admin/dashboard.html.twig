{% extends 'base.html.twig' %}

{% block body %}

<div class="container my-5">
<p>admin/dashboard.html.twig.html.twig</p>
    <!-- ACTIONS -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="fw-bold mb-4">📊 Dashboard Admin</h1>
        <a href="{{ path('app_admin') }}" class="btn btn-outline-dark rounded-pill text-center">
            Retour
        </a>
    </div>

    <!-- STATS -->
    <div class="row g-4 mb-5">

        <div class="col-md-4">
            <div class="product-card p-4 text-center">
                <h6 class="text-muted">Produits</h6>
                <h2 class="fw-bold">{{ totalProducts }}</h2>
            </div>
        </div>

        <div class="col-md-4">
            <div class="product-card p-4 text-center">
                <h6 class="text-muted">Commandes</h6>
                <h2 class="fw-bold">{{ totalOrders }}</h2>
            </div>
        </div>

        <div class="col-md-4">
            <div class="product-card p-4 text-center">
                <h6 class="text-muted">Chiffre d'affaires</h6>
                <h2 class="fw-bold text-corail">{{ totalRevenue }} €</h2>
            </div>
        </div>

    </div>

    <!-- TOP PRODUITS -->
    <div class="product-card p-4">

        <h4 class="fw-bold mb-3">🔥 Produits les plus vendus</h4>

        <div class="table-responsive">
            <table class="table align-middle">

                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>Produit</th>
                        <th>Ventes</th>
                    </tr>
                </thead>

                <tbody>
                {% for product in topProducts %}
                    <tr>
                        <td class="fw-bold">

                            {% if loop.index == 1 %}
                                🥇
                            {% elseif loop.index == 2 %}
                                🥈
                            {% elseif loop.index == 3 %}
                                🥉
                            {% else %}
                                {{ loop.index }}
                            {% endif %}

                        </td>

                        <td>{{ product.productName }}</td>

                        <td class="fw-semibold">
                            {{ product.totalSold }}
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="3" class="text-center">
                            Aucune vente
                        </td>
                    </tr>
                {% endfor %}
                </tbody>

            </table>
        </div>

    </div>

</div>

{% endblock %}