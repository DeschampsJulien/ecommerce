{% extends 'base.html.twig' %}

{% block title %}Mes commandes{% endblock %}

{% block body %}

<div class="container my-5">
    <p>account/orders.html.twig</p>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="fw-bold">📦 Mes commandes</h1>

        <div class="d-flex gap-2">
            <a href="{{ path('app_account') }}" class="btn btn-outline-dark rounded-pill text-center">
                Retour
            </a>
        </div>
    </div>
    {# <h1 class="fw-bold mb-4">📦 Mes commandes</h1> #}

    {% if orders is empty %}
        <div class="text-center py-5">
            <p>Vous n'avez encore passé aucune commande 😢</p>
            <a href="{{ path('app_products') }}" class="btn-tropical mt-3">
                Découvrir la boutique
            </a>
        </div>
    {% else %}

        {% for order in orders %}
            <div class="product-card p-4 mb-4">

                <!-- HEADER -->
                <div class="d-flex flex-column flex-md-row justify-content-between mb-3">

                    <div>
                        <strong>Commande #{{ order.id }}</strong><br>
                        <span class="text-muted small">
                            {{ order.createdAt ? order.createdAt|date('d/m/Y') : '' }}
                        </span>
                    </div>

                    <!-- STATUS -->
                    <div class="mt-2 mt-md-0">
                        {% if order.status == 'paid' %}
                            <span class="badge bg-success">Payée</span>
                        {% elseif order.status == 'pending' %}
                            <span class="badge bg-warning text-dark">En attente</span>
                        {% else %}
                            <span class="badge bg-secondary">{{ order.status }}</span>
                        {% endif %}
                    </div>

                </div>

                <hr>

                <!-- PRODUITS -->
                {% for item in order.orderItems %}
                    <div class="d-flex justify-content-between align-items-center mb-2">

                        <div>
                            <strong>{{ item.productName }}</strong><br>
                            <span class="text-muted small">
                                Taille : {{ item.size }} | Qté : {{ item.quantity }}
                            </span>
                        </div>

                        <div class="fw-semibold">
                            {{ item.price * item.quantity }} €
                        </div>

                    </div>
                {% endfor %}

                <hr>

                <!-- FOOTER -->
                <div class="d-flex flex-column flex-md-row justify-content-between align-items-center">

                    <div class="fw-bold fs-5">
                        Total : {{ order.total }} €
                    </div>

                    <div class="mt-3 mt-md-0">

                        {% if order.status != 'paid' %}
                            <a href="{{ path('order_pay', {id: order.id}) }}" class="btn-view">
                                💳 Payer
                            </a>
                        {% else %}
                            <span class="text-success fw-semibold">
                                ✔ Commande réglée
                            </span>
                            <a href="{{ path('order_invoice', {id: order.id}) }}" class="btn btn-outline-dark btn-sm ms-2">
                                🧾 Facture PDF
                            </a>
                        {% endif %}

                    </div>

                </div>

            </div>
        {% endfor %}

    {% endif %}

</div>

{% endblock %}