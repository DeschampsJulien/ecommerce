{% extends 'base.html.twig' %}

{% block title %}Détail commande #{{ order.id }}{% endblock %}

{% block body %}

<h1>Commande #{{ order.id }}</h1>

<p>
    <strong>Statut :</strong> {{ order.status }}<br>
    <strong>Total :</strong> {{ order.total }} €
</p>

<h2>Produits commandés</h2>

{% if order.orderItems is empty %}
    <p>Aucun produit dans cette commande.</p>
{% else %}
    <table>
        <thead>
            <tr>
                <th>Produit</th>
                <th>Taille</th>
                <th>Prix unitaire</th>
                <th>Quantité</th>
                <th>Sous-total</th>
            </tr>
        </thead>
        <tbody>
            {% for item in order.orderItems %}
                <tr>
                    <td>{{ item.productName }}</td>
                    <td>{{ item.size }}</td>
                    <td>{{ item.price }} €</td>
                    <td>{{ item.quantity }}</td>
                    <td>{{ (item.price * item.quantity)|number_format(2, ',', ' ') }} €</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
{% endif %}
<p>
    <a href="{{ path('account_orders') }}">← Retour aux commandes</a>
</p>
{% endblock %}