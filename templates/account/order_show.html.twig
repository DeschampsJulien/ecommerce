{% extends 'base.html.twig' %}

{% block title %}Détail commande #{{ order.id }}{% endblock %}

{% block body %}
<h1>accout/order_show.html.twig</h1>
<h1>Commande #{{ order.id }}</h1>

<p>
    <strong>Statut :</strong> {{ order.status }}<br>
    <strong>Total :</strong> {{ order.total }} €
</p>

<h2>Produits commandés</h2>

{% if order.orderItems is empty %}
    <p>Aucun produit dans cette commande.</p>
{% else %}
    <table>
        <thead>
            <tr>
                <th>Produit</th>
                <th>Taille</th>
                <th>Prix unitaire</th>
                <th>Quantité</th>
                <th>Sous-total</th>
            </tr>
        </thead>
        <tbody>
            {% for item in order.orderItems %}
                <tr>
                    <td>{{ item.productName }}</td>
                    <td>{{ item.size }}</td>
                    <td>{{ item.price }} €</td>
                    <td>{{ item.quantity }}</td>
                    <td>{{ (item.price * item.quantity)|number_format(2, ',', ' ') }} €</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
{% endif %}
<p>
    <a href="{{ path('account_orders') }}">← Retour aux commandes</a>
</p>
{# {% if order.status == 'pending' %}
    <h3>Paiement</h3>
    <p>Montant à payer : {{ order.total }} €</p>
    <p>Simulation de paiement Stripe en sandbox...</p>
    <button disabled>Payer maintenant (sandbox)</button>
    <a href="{{ path('order_pay', {id: order.id}) }}" class="btn btn-success">
        Payer maintenant
    </a>
{% else %}
    <p>Paiement effectué</p>
{% endif %} #}
{% if order.status != 'paid' %}
    <a href="{{ path('order_pay', {id: order.id}) }}" class="btn btn-success">
        Payer maintenant
    </a>
{% else %}
    <p class="text-success"><strong>Commande déjà payée ✅</strong></p>
{% endif %}

{% endblock %}