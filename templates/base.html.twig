<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>{% block title %}Ecommerce{% endblock %}</title>
    <style>
        nav ul {
            list-style: none;
            padding: 0;
            display: flex;
            gap: 15px;
        }
        nav a.active {
            font-weight: bold;
            text-decoration: underline;
        }
    </style>
</head>
<body>

<nav>
    <ul>
        <li>
            <a href="{{ path('home') }}"
               class="{% if app.request.attributes.get('_route') == 'home' %}active{% endif %}">
                Accueil
            </a>
        </li>

        {% if app.user %}
            <li>
                <a href="{{ path('products') }}"
                   class="{% if app.request.attributes.get('_route') == 'products' %}active{% endif %}">
                    Boutique
                </a>
            </li>
            <li>
                <a href="{{ path('cart') }}">
                    🛒 Panier ({{ cartItemCount }})
                </a>
            </li>
            <li>
                <a href="{{ path('account') }}">
                    Mon compte
                </a>
            </li>
            <li>
                <a href="{{ path('app_logout') }}">
                    Se déconnecter
                </a>
            </li>
        {% else %}
            <li>
                <a href="{{ path('app_register') }}"
                   class="{% if app.request.attributes.get('_route') == 'app_register' %}active{% endif %}">
                    S’inscrire
                </a>
            </li>
            <li>
                <a href="{{ path('app_login') }}"
                   class="{% if app.request.attributes.get('_route') == 'app_login' %}active{% endif %}">
                    Se connecter
                </a>
            </li>
        {% endif %}
    </ul>
</nav>

<hr>

{% block body %}{% endblock %}

</body>
</html>