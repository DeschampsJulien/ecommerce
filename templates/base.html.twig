<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>{% block title %}Stubborn{% endblock %}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        :root {
            --lagon: #00a8cc;
            --corail: #ff6f61;
            --sable: #fff8f0;
            --sun: #ffb347;
        }

        body {
            background: var(--sable);
            font-family: 'Segoe UI', sans-serif;
        }

        /* --- NAVBAR --- */
        .navbar {
            background: rgba(0,168,204,0.95);
            backdrop-filter: blur(8px);
            transition: all 0.3s ease;
            z-index: 1000;
        }

        .navbar-brand img {
            width: 140px;
            transition: transform 0.3s;
        }

        .navbar-brand img:hover {
            transform: scale(1.05) rotate(-2deg);
        }

        .nav-link {
            color: #fff !important;
            position: relative;
            font-weight: 500;
        }

        .nav-link::after {
            content: "";
            position: absolute;
            width: 0%;
            height: 2px;
            background: var(--corail);
            bottom: 0;
            left: 0;
            transition: 0.3s;
        }

        .nav-link:hover::after,
        .nav-link.active::after {
            width: 100%;
        }

        /* --- PANIER BADGE --- */
        .cart-badge {
            background: var(--corail);
            color: white;
            font-size: 12px;
            padding: 3px 8px;
            border-radius: 50px;
            margin-left: 5px;
        }

        /* --- BOUTONS --- */
        .btn-tropical {
            background: linear-gradient(135deg, #ffb347, #ff6f61);
            border: none;
            color: #fff;
            border-radius: 30px;
            padding: 8px 16px;
            transition: all 0.3s;
        }

        .btn-tropical:hover {
            transform: scale(1.05);
            box-shadow: 0 8px 20px rgba(0,0,0,0.2);
        }

        /* --- IMAGES FIX --- */
        img {
            max-width: 100%;
            height: auto;
            display: block;
        }

        /* --- CARDS PRODUITS --- */
        .product-card {
            border-radius: 16px;
            overflow: hidden;
            background: #fff;
            box-shadow: 0 8px 20px rgba(0,0,0,0.12);
            transition: all 0.3s ease;
        }

        .product-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 18px 35px rgba(0,0,0,0.18);
        }

        .product-img {
            height: 260px;
            overflow: hidden;
        }

        .product-img img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.5s ease;
        }

        .product-card:hover img {
            transform: scale(1.1);
        }

        .product-body {
            padding: 15px;
        }

        .product-title {
            font-size: 16px;
            font-weight: 600;
        }

        .product-price {
            color: var(--corail);
            font-weight: bold;
            margin-bottom: 10px;
        }

        /* --- BOUTON PRODUIT --- */
        .btn-view {
            display: inline-block;
            padding: 10px 16px;
            border-radius: 30px;
            background: linear-gradient(135deg, #ffb347, #ff6f61);
            color: white;
            font-size: 14px;
            text-decoration: none;
            transition: all 0.3s ease;
        }

        .btn-view:hover {
            transform: translateY(-2px) scale(1.05);
            box-shadow: 0 8px 20px rgba(0,0,0,0.2);
            color: white;
        }

        /* --- CONTENU --- */
        main {
            min-height: 70vh;
        }

        /* --- FOOTER --- */
        .footer {
            background: var(--lagon);
            color: #fff;
        }

        .footer a {
            color: #fff;
            text-decoration: none;
        }

        .footer a:hover {
            color: var(--corail);
            text-decoration: underline;
        }
    </style>

    {% block stylesheets %}{% endblock %}
</head>

<body>

<!-- NAVBAR  -->
<nav class="navbar navbar-expand-lg navbar-dark sticky-top shadow-sm">
    <div class="container">

        <a class="navbar-brand" href="{{ path('app_home') }}">
            <img src="{{ asset('images/logo.png') }}" alt="logo">
        </a>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarContent">
            <ul class="navbar-nav ms-auto align-items-lg-center">

                <li class="nav-item">
                    <a class="nav-link {% if app.request.attributes.get('_route') == 'app_home' %}active{% endif %}" href="{{ path('app_home') }}">
                        Accueil
                    </a>
                </li>

                {% if app.user %}
                    <li class="nav-item">
                        <a class="nav-link {% if app.request.attributes.get('_route') == 'app_products' %}active{% endif %}" href="{{ path('app_products') }}">Boutique</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link {% if app.request.attributes.get('_route') == 'app_cart' %}active{% endif %}" href="{{ path('app_cart') }}">
                            🛒 Panier
                            {% if cartItemCount > 0 %}
                                <span class="cart-badge">{{ cartItemCount }}</span>
                            {% endif %}
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link {% if app.request.attributes.get('_route') == 'app_account' %}active{% endif %}" href="{{ path('app_account') }}">Mon compte</a>
                    </li>

                    {% if is_granted('ROLE_ADMIN') %}
                        <li class="nav-item">
                            <a class="nav-link {% if app.request.attributes.get('_route') == 'app_admin' %}active{% endif %}" href="{{ path('app_admin') }}">Admin</a>
                        </li>
                    {% endif %}

                    <li class="nav-item ms-lg-3">
                        <a class="btn btn-tropical btn-sm" href="{{ path('app_logout') }}">
                            Déconnexion
                        </a>
                    </li>

                {% else %}
                    <li class="nav-item">
                        <a class="nav-link {% if app.request.attributes.get('_route') == 'app_register' %}active{% endif %}" href="{{ path('app_register') }}">S'inscrire</a>
                    </li>

                    <li class="nav-item ms-lg-2">
                        <a class="btn btn-tropical btn-sm" href="{{ path('app_login') }}">
                            Connexion
                        </a>
                    </li>
                {% endif %}

            </ul>
        </div>
    </div>
</nav>

<!-- CONTENU -->
<main class="container my-5">
    {% block body %}{% endblock %}
</main>

<!-- FOOTER -->
<footer class="footer mt-auto py-4">
    <div class="container">
        <div class="row">

            <div class="col-md-4 mb-3">
                <h5>Stubborn</h5>
                <p>Don't compromise on your look 🌴</p>
            </div>

            <div class="col-md-4 mb-3">
                <h6>Informations</h6>
                <ul class="list-unstyled">
                    <li><a href="#">Mentions légales</a></li>
                    <li><a href="#">CGV</a></li>
                    <li><a href="#">Politique de confidentialité</a></li>
                </ul>
            </div>

            <div class="col-md-4 mb-3">
                <h6>Contact</h6>
                <p>Email : stubborn@blabla.com</p>
                <p>Adresse : Londres</p>
            </div>

        </div>

        <div class="text-center mt-3">
            <small>© {{ "now"|date("Y") }} Stubborn - Tous droits réservés</small>
        </div>
    </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>