{% extends 'base.html.twig' %}

{% block title %}Mon panier{% endblock %}

{% block body %}

<div class="container my-5">
<p>cart/index.html.twig</p>
    <h1 class="fw-bold mb-4">🛒 Mon panier</h1>

    {% if cart is empty %}

        <div class="text-center py-5">
            <p>Votre panier est vide 😢</p>
            <a href="{{ path('app_products') }}" class="btn-tropical mt-3">
                Voir la boutique
            </a>
        </div>

    {% else %}

        {% for item in cart %}
            <div class="product-card d-flex flex-column flex-md-row align-items-center p-3 mb-3">

                <!-- IMAGE -->
                <div style="width:100px; height:100px; display:flex; align-items:center; justify-content:center;">
                    <img src="{{ asset('images/' ~ item.image) }}"
                         alt="{{ item.name }}"
                         style="max-width:100%; max-height:100%; object-fit:contain;">
                </div>

                <!-- INFOS -->
                <div class="ms-3 flex-grow-1">
                    <div class="fw-bold">{{ item.name }}</div>
                    <div class="text-muted small">Taille : {{ item.size }}</div>
                    <div class="text-corail fw-semibold">{{ item.price }} €</div>
                </div>

                <!-- QUANTITÉ -->
                <div class="mx-3 text-center">
                    <div class="small text-muted">Qté</div>
                    <div class="fw-bold">{{ item.quantity }}</div>
                </div>

                <!-- TOTAL -->
                <div class="fw-bold mx-3">
                    {{ item.price * item.quantity }} €
                </div>

                <!-- SUPPRIMER -->
                <a href="{{ path('cart_remove', {key: item.key}) }}" class="btn btn-danger btn-sm rounded-pill">
                    ✕
                </a>

            </div>
        {% endfor %}

        <!-- TOTAL GLOBAL -->
        <div class="text-end mt-4">
            <h3 class="fw-bold">Total : {{ total }} €</h3>
        </div>

        <!-- BOUTONS ACTION -->
        <div class="d-flex flex-column flex-md-row justify-content-between gap-3 mt-4">

            <a href="{{ path('app_products') }}" class="btn-tropical text-center">
                ← Retour à la boutique
            </a>

            {% if app.user %}
                <a href="{{ path('cart_checkout') }}" class="btn-view text-center">
                    Finaliser la commande
                </a>
            {% else %}
                <a href="{{ path('app_login') }}" class="btn-view text-center">
                    Se connecter pour commander
                </a>
            {% endif %}

        </div>

    {% endif %}

</div>

{% endblock %}